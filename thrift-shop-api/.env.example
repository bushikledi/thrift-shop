# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/thriftshop

# Redis
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Encryption key for sensitive stored data (vendor payout/bank details).
# Optional: if unset, a key is derived from JWT_SECRET. Prefer a dedicated
# 64-character hex value so it can be rotated independently of JWT_SECRET.
# Generate one with: openssl rand -hex 32
# ENCRYPTION_KEY=

# S3/MinIO Storage
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=thriftshop
S3_REGION=us-east-1

# Email (SMTP - MailHog for local, SendGrid for production)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@thriftshop.com

# SendGrid (production)
# SENDGRID_API_KEY=your-sendgrid-api-key

# Twilio SMS (optional)
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+1234567890

# Application
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001

# Logging
LOG_LEVEL=debug

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ================================
# Stripe (optional - card payments)
# ================================
# Without STRIPE_SECRET_KEY the platform runs cash-on-delivery only and card
# checkout is rejected with a clear error.
# Test keys: https://dashboard.stripe.com/test/apikeys
# STRIPE_SECRET_KEY=sk_test_...
# Webhook secret from `stripe listen --forward-to localhost:3000/api/v1/payments/webhook`
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_CURRENCY=usd
